# Server Configuration
PORT=5000

# MongoDB Connection URI
# For local: mongodb://127.0.0.1:27017/teamtask
# For Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/teamtask
MONGODB_URI=mongodb://127.0.0.1:27017/teamtask

# JWT Secret Key (use a long, random string in production)
JWT_SECRET=your_jwt_secret_key_here
